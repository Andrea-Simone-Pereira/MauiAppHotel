<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.TelaInicial"
             Title="TelaInicial">
    <ScrollView>
        <VerticalStackLayout Spacing="30" Padding="30" VerticalOptions="Center">
        <Label Text="INTERCONTINENTAL HOTEL"
               FontSize="25"
               FontFamily="Kalam"
               TextColor="{StaticResource Primary}"
               HorizontalOptions="Center"/>

            <Frame CornerRadius="20" Padding="0" IsClippedToBounds="True" HeightRequest="200">
                <Image Source="hotel.png" 
                       Aspect="AspectFill"
                       HorizontalOptions="Fill" />
            </Frame>

            <Button Text="Entrar"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    Margin="0, 10, 0, 0"
                    Clicked="Button_OnEntrarClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>