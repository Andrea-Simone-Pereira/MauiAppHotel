<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.Sobre"
             Title="Sobre"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Padding="30"
                             Spacing="20"
                             VerticalOptions="Center">

            <Border BackgroundColor="{StaticResource Primary}"
                    StrokeThickness="0"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15"/>
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="15">

                    <Label Text="Sobre o projeto"
                           FontSize="28"
                           FontAttributes="Bold"
                           FontFamily="Kalam"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <BoxView HeightRequest="1" Color="White" Opacity="0.5" Margin="0,10"/>

                    <Label Text="Aplicativo desenvolvido para simular contratação de hospedagem em um hotel."
                           FontSize="16"
                           FontFamily="Kalam"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Desenvolvedora:"
                           FontAttributes="Bold"
                           FontSize="18"
                           FontFamily="Kalam"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="Andréa Simone Pereira"
                           FontSize="16"
                           FontFamily="Kalam"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>

                    <Label Text="2026"
                           FontSize="16"
                           FontFamily="Kalam"
                           TextColor="White"
                           HorizontalTextAlignment="Center"
                           Margin="0,10,0,0"/>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>